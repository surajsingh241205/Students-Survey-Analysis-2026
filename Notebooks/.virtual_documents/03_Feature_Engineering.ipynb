


import pandas as pd
import numpy as np

df = pd.read_csv("../data/cleaned/student_career_cleaned.csv")

df.head()





for value in df["daily_study_hours"].unique():
    print(repr(value))


study_hours_mapping = {
    "Less Than 1 Hour": 0.5,
    "1–2 Hours": 1.5,
    "2–4 Hours": 3,
    "4–6 Hours": 5,
    "More Than 6 Hours": 7
}

df["study_hours_numeric"] = (
    df["daily_study_hours"]
    .map(study_hours_mapping)
)

df[["daily_study_hours","study_hours_numeric"]].head()


df["expected_salary"].unique()


salary_mapping = {
    "Below ₹3 Lpa": 2.5,
    "₹3–5 Lpa": 4,
    "₹5–8 Lpa": 6.5,
    "₹8–12 Lpa": 10,
    "Above ₹12 Lpa": 15
}

df["expected_salary_numeric"] = (
    df["expected_salary"]
    .map(salary_mapping)
)


df["expected_salary_numeric"]


resume_mapping = {
    "Yes":1,
    "No":0
}

df["resume_numeric"] = (
    df["has_resume"]
    .map(resume_mapping)
)


linkedin_mapping = {
    "Yes":1,
    "No":0
}

df["linkedin_numeric"] = (
    df["has_linkedin"]
    .map(linkedin_mapping)
)


github_mapping = {
    "Yes":1,
    "No":0
}

df["github_numeric"] = (
    df["has_github"]
    .map(github_mapping)
)


certification_mapping = {
    "Yes":1,
    "No":0
}

df["certification_numeric"] = (
    df["has_certification"]
    .map(certification_mapping)
)


recommend_mapping = {
    "Yes":1,
    "No":0,
    "Maybe":0.5
}

df["recommend_numeric"] = (
    df["recommend_learning"]
    .map(recommend_mapping)
)


project_mapping = {
    "0":0,
    "1-2":2,
    "3-5":4,
    "6-10":8,
    "More than 10":12
}

df["project_count"] = (
    df["project_count"]
    .map(project_mapping)
)


df["employability_score"] = (
      df["resume_numeric"]
    + df["linkedin_numeric"]
    + df["github_numeric"]
    + df["certification_numeric"]
    + df["project_count"]
    + df["technical_confidence"]
    + df["career_confidence"]
)


