df.info()


df.head()








total_students = len(df)

print(f"Total Survey Responses: {total_students}")





student_type = df["student_type"].value_counts()

student_type


plt.figure(figsize=(7,7))

student_type.plot(
    kind="pie",
    autopct="%1.1f%%",
    startangle=90
)

plt.ylabel("")
plt.title("Distribution of Student Types")

plt.show()








