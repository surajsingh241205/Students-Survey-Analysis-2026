    df[col] = pd.to_numeric(df[col], errors="coerce")

print("Numeric columns converted successfully.")


df.info()


df[numeric_columns].describe()


yes_no_columns = [
    "has_certification",
    "has_resume",
    "has_linkedin",
    "has_github",
    "recommend_learning"
]
for col in yes_no_columns:
    df[col] = (
        df[col]
        .str.strip()
        .str.title()
        .replace({
            "Y": "Yes",
            "N": "No"
        })
    )

print("Yes/No columns standardized successfully.")





multi_select_columns = [
    "technical_skills",
    "learning_skill"
]


def clean_multiselect(value):
    if pd.isna(value):
        return value

    # Split values
    items = [item.strip().title() for item in value.split(",")]

    # Remove duplicates
    items = list(set(items))

    # Sort alphabetically
    items.sort()

    return ", ".join(items)

for col in multi_select_columns:
    df[col] = df[col].apply(clean_multiselect)

print("Multi-select columns cleaned successfully.")


